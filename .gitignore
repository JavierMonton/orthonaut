# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Logs ---
*.log
logs/

# --- Environment / secrets ---
.env
.env.*
!.env.example
!.env.sample

# --- Python (local tooling) ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.venv/
venv/

# --- Frontend / Node ---
frontend/node_modules/
frontend/dist-ssr/
frontend/.vite/
frontend/.cache/
# frontend/dist/ is a build artifact: CI (.github/workflows/deploy.yml) builds it
# and publishes it to the `deploy` branch, which Toolforge builds from. It is NOT
# tracked on `main`.
frontend/dist/

# --- Orthonaut config (contains secrets) ---
/orthonaut.toml

# --- Backend / Rust ---
/target/
backend/target/

# --- Local SQLite database (regenerated on first run; may contain OAuth tokens) ---
backend/orthonaut.db
backend/orthonaut.db-journal
backend/orthonaut.db-wal
backend/orthonaut.db-shm
